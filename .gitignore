# ===========================
# Dillo Backup – Project .gitignore
# ===========================

# ─── Python ─────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
*.egg-info/
*.egg
.pytest_cache/
.mypy_cache/

# Virtual environments
backend/venv/
venv/
.venv/

# ─── SQLite databases ───────────────────────────
*.db
*.db-journal
*.db-wal
*.db-shm

# ─── Environment / secrets ──────────────────────
.env
.env.*

# ─── Backend logs ───────────────────────────────
backend/logs/

# ─── Frontend (Next.js) ─────────────────────────
frontend/.next/
frontend/node_modules/
frontend/out/
frontend/coverage/
frontend/.pnp.*
frontend/.yarn/*
!frontend/.yarn/patches
!frontend/.yarn/plugins
!frontend/.yarn/releases
!frontend/.yarn/versions
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
*.tsbuildinfo
next-env.d.ts

# ─── Build & distribution artifacts ─────────────
build/
dist/
*.spec

# Downloaded binaries (portable Node.js, etc.)
node.exe

# ─── Installer build outputs ────────────────────
installer/assets/*.ico
installer/assets/*.icns
installer/dillo.ico

# ─── OS-specific ────────────────────────────────
.DS_Store
Thumbs.db
Desktop.ini
ehthumbs.db

# ─── IDE / editor ───────────────────────────────
.vscode/
.idea/
*.swp
*.swo
*~

# ─── Cursor / AI agent local-only files ─────────
# Cursor config and rules are local-only (not version-controlled)
.cursor/
*.mdc

# ─── Internal context / agent memory (local-only) ──
# Kept on disk for the agent to read/update, but never committed
PROJECT_JOURNAL.md
PRODUCT_CONTEXT.md
AGENTS.md
MEMORY.md
